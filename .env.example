# Required — Railway PostgreSQL (auto-set when you add Postgres plugin)
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Session security — set a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# Real cash calculation cutoff (default matches existing production logic)
REAL_CASH_CUTOFF=2026-05-29

# Optional — show default login hint on login page (off by default)
# SHOW_LOGIN_HINT=true

# Optional — restrict CORS to specific origins (comma-separated). Leave empty for legacy behavior.
# CORS_ORIGINS=https://your-app.up.railway.app

# Courier integrations (move tokens out of code in production)
POSTEX_TOKEN=
POSTEX_BASE=https://api.postex.pk/services/integration/api/order
DIGI_PHONE=
DIGI_PASS=
DIGI_BASE=https://dev.digidokaan.pk/api/v1/digidokaan

# Shopify returns module
SHOPIFY_TOKEN=
SHOPIFY_STORE=womencomforts.myshopify.com

# Railway / local
PORT=5000
